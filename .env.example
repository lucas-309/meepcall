# Recall.ai workspace API
# Pick the URL for your workspace region:
#   US PAYG:    https://us-west-2.recall.ai
#   US Monthly: https://us-east-1.recall.ai
#   EU:         https://eu-central-1.recall.ai
#   JP:         https://ap-northeast-1.recall.ai
RECALLAI_API_URL=https://us-west-2.recall.ai

# Recall API key (Token auth, prefixed `Token <key>` server-side)
RECALLAI_API_KEY=

# Anthropic API key for AI summaries — uses claude-sonnet-4-6 directly
ANTHROPIC_API_KEY=

# Optional: route ad-hoc recordings (⌘⇧R, Record Audio button, comm-app
# banner) through the Recall Desktop SDK instead of the local whisper.cpp
# pipeline. Useful for A/B-testing Recall transcription quality. Costs
# Recall credits ($0.50/hr recording + $0.15/hr transcription) when on.
# Unset or set to 0 to use the free local pipeline.
# MEEPCALL_USE_RECALL_FOR_ADHOC=1

# Optional: run BOTH local whisper and Recall in parallel on the same
# recording (side-by-side comparison mode). Local writes to the meeting
# note as normal; Recall transcripts print to terminal only. Same Recall
# cost as USE_RECALL_FOR_ADHOC. Stop hits both engines.
# MEEPCALL_COMPARE_MODE=1

# Optional: per-run override for the recallai_streaming provider config.
# Defaults: lang=en, mode=prioritize_low_latency (English real-time).
# For multilingual auto-detect: lang=auto, mode=prioritize_accuracy
# (transcripts batch every 3-10 minutes — not real-time).
# MEEPCALL_RECALL_LANG=auto
# MEEPCALL_RECALL_MODE=prioritize_accuracy

# Cut whisper chunks at natural phrase boundaries (silence) instead of the
# default 3 s/2 s sliding window. Variable-size chunks (1-5 s) — usually
# better quality on conversational audio because words don't get cut at
# fixed time slices. Worse on continuous audio (music, noisy rooms) since
# it'll just hit the 5 s max cap every time. Off by default.
# MEEPCALL_PHRASE_VAD=1

# Whisper diagnostics (local pipeline)
# Verbose log of every segment whisper produces and which filter dropped it.
# Useful for "where did my lyrics go?" debugging.
# MEEPCALL_DEBUG_WHISPER=1
#
# Bypass all post-whisper text filters (hallucination + dedup). Overlap-skip
# still runs (correctness). Use as a diagnostic to see what whisper actually
# emits before our heuristics touch it.
# MEEPCALL_WHISPER_NO_FILTERS=1
#
# Whisper's no-speech threshold. Default 0.6 is tuned for spoken speech.
# Lower (0.3-0.4) for music — singing has different acoustic features and
# whisper often classifies sung audio as silence. Higher (0.7-0.8) suppresses
# hallucinations on quiet/noisy audio.
# MEEPCALL_NO_SPEECH_THOLD=0.4
