# Recall.ai workspace API
# Pick the URL for your workspace region:
#   US PAYG:    https://us-west-2.recall.ai
#   US Monthly: https://us-east-1.recall.ai
#   EU:         https://eu-central-1.recall.ai
#   JP:         https://ap-northeast-1.recall.ai
RECALLAI_API_URL=https://us-west-2.recall.ai

# Recall API key (Token auth, prefixed `Token <key>` server-side)
RECALLAI_API_KEY=

# Anthropic API key for AI summaries — uses claude-sonnet-4-6 directly
ANTHROPIC_API_KEY=
