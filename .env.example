# Recall.ai workspace API
# Pick the URL for your workspace region:
#   US PAYG:    https://us-west-2.recall.ai
#   US Monthly: https://us-east-1.recall.ai
#   EU:         https://eu-central-1.recall.ai
#   JP:         https://ap-northeast-1.recall.ai
RECALLAI_API_URL=https://us-west-2.recall.ai

# Recall API key (Token auth, prefixed `Token <key>` server-side)
RECALLAI_API_KEY=

# Anthropic API key for AI summaries — uses claude-sonnet-4-6 directly
ANTHROPIC_API_KEY=

# Optional: route ad-hoc recordings (⌘⇧R, Record Audio button, comm-app
# banner) through the Recall Desktop SDK instead of the local whisper.cpp
# pipeline. Useful for A/B-testing Recall transcription quality. Costs
# Recall credits ($0.50/hr recording + $0.15/hr transcription) when on.
# Unset or set to 0 to use the free local pipeline.
# MEEPCALL_USE_RECALL_FOR_ADHOC=1
